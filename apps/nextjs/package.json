{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.13.0",
    "npm": "please use pnpm",
    "yarn": "please use pnpm"
  },
  "type": "module",
  "scripts": {
    "prepare": "pnpm chakra:typegen",
    "dev": "next dev -p 4001",
    "build": "next build",
    "start": "next start -p 8080",
    "start:local": "pnpm build && pnpm start",
    "cz": "git-cz",
    "lint": "biome check src",
    "lint:fix": "biome check --write --unsafe src",
    "test": "vitest",
    "test:ci": "vitest",
    "test:unit": "vitest --project=unit",
    "test:integration": "vitest --project=integration",
    "test:storybook": "vitest --project=storybook",
    "tsc": "tsc",
    "tsc:scripts": "tsc --p ./scripts/",
    "codegen": "pnpm codegen:download && graphql-codegen --config codegen.ts",
    "codegen:watch": "pnpm codegen:download && graphql-codegen --config codegen.ts --watch",
    "codegen:download": "env-cmd -f ./.env.local tsx scripts/codegen/download.ts",
    "codegen:prod": "pnpm codegen:download:prod && graphql-codegen",
    "codegen:download:prod": "echo ENV_JSON > ./env.json && env-cmd -f ./.env.json npx tsx scripts/codegen/download.ts",
    "codegen:ci": "graphql-codegen --config codegen.ts",
    "new:queryMock": "tsx ./scripts/newQueryMock.ts",
    "new:mutationMock": "tsx ./scripts/newMutationMock.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic",
    "chromatic:local": "env-cmd -f ./.env.local chromatic",
    "chakra:typegen": "npx @chakra-ui/cli typegen src/chakra-ui/theme/theme.ts"
  },
  "dependencies": {
    "@apollo/client": "4.2.0",
    "@chakra-ui/react": "3.35.0",
    "@date-io/date-fns": "^1.3.13",
    "@emotion/react": "11.14.0",
    "@graphql-typed-document-node/core": "3.2.0",
    "@hello-pangea/dnd": "18.0.1",
    "@pdfslick/react": "^3.0.1",
    "@react-hook/hover": "^4.0.0",
    "@react-hook/latest": "^1.0.3",
    "@react-hook/passive-layout-effect": "^1.2.1",
    "@react-hook/resize-observer": "^1.2.4",
    "date-fns": "^2.23.0",
    "emoji-mart": "^3.0.1",
    "emotion-theming": "^11.0.0",
    "fast-deep-equal": "^3.1.3",
    "firebase": "^12.0.0",
    "focus-visible": "^5.2.0",
    "formik": "^2.2.9",
    "graphql": "16.14.0",
    "subscriptions-transport-ws": "0.11.0",
    "jotai": "^2.12.5",
    "lodash-es": "4.17.23",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "prosemirror-commands": "1.7.1",
    "prosemirror-history": "1.5.0",
    "prosemirror-inputrules": "1.5.1",
    "prosemirror-keymap": "1.2.3",
    "prosemirror-model": "1.25.7",
    "prosemirror-schema-basic": "1.2.4",
    "prosemirror-schema-list": "1.5.1",
    "prosemirror-state": "1.4.4",
    "prosemirror-suggest": "3.0.0",
    "prosemirror-view": "1.41.8",
    "prosemirror-transform": "1.12.0",
    "use-prosemirror": "1.3.0",
    "raf-schd": "^4.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "5.6.0",
    "react-intersection-observer": "^8.32.1",
    "react-player": "^2.9.0",
    "recoil": "^0.7.6",
    "resize-observer-polyfill": "^1.5.1",
    "rxjs": "7.8.2",
    "shortid": "2.2.17",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.5",
    "@biomejs/biome": "^2.3.8",
    "@graphql-codegen/cli": "7.0.0",
    "@graphql-codegen/introspection": "6.0.0",
    "@graphql-codegen/schema-ast": "6.0.0",
    "@graphql-codegen/typed-document-node": "6.1.8",
    "@graphql-codegen/typescript": "6.0.1",
    "@graphql-codegen/typescript-operations": "6.0.2",
    "@mdx-js/react": "^1.6.22",
    "@parcel/watcher": "2.5.6",
    "@storybook/addon-a11y": "10.4.0",
    "@storybook/addon-docs": "10.4.0",
    "@storybook/addon-vitest": "10.4.0",
    "@storybook/nextjs-vite": "10.4.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/babel__core": "^7",
    "@types/cross-spawn": "^6.0.2",
    "@types/emoji-mart": "^3.0.9",
    "@types/lodash-es": "^4.17.6",
    "@types/mdx-js__react": "^1.5.5",
    "@types/node": "^24.10.4",
    "@types/raf-schd": "^4.0.1",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "@types/shortid": "^0.0.29",
    "@types/testing-library__jest-dom": "^5.14.5",
    "@types/uuid": "^8.3.4",
    "@types/yargs": "^17",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "babel-loader": "^8.3.0",
    "biome-config": "workspace:*",
    "change-case": "^4.1.2",
    "chromatic": "17.0.0",
    "commitizen": "^4.2.4",
    "consola": "^2.15.3",
    "cross-env": "^7.0.3",
    "cross-spawn": "^7.0.6",
    "cz-conventional-changelog": "^3.3.0",
    "deepmerge": "^4.2.2",
    "empty": "^0.10.1",
    "env-cmd": "^10.1.0",
    "fast-glob": "^3.2.12",
    "happy-dom": "^20.9.0",
    "husky": "^7.0.4",
    "hygen": "^6.2.11",
    "inflection": "^2.0.0",
    "mockdate": "^3.0.5",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "playwright": "^1.60.0",
    "storybook": "10.4.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "utility-types": "3.11.0",
    "vite": "8.0.13",
    "vitest": "4.1.8",
    "yargs": "^17.6.2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
